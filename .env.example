# URL do webhook do n8n que retorna o owner designado e a lista de owners
# ativos, dado email e/ou cpf do aluno (GET <url>?email={email}&cpf={cpf}).
#
# Lida só no servidor por api/responsavel.js — nunca é exposta ao navegador,
# por isso não usa prefixo público (NEXT_PUBLIC_/VITE_ não se aplicam: este
# projeto é HTML/CSS/JS puro, sem bundler/build).
#
# Copie este arquivo para .env e preencha com a URL real (não versione .env).
# Cadastre a mesma variável também no Vercel: Project Settings → Environment
# Variables, nos ambientes Production/Preview/Development.
WEBHOOK_RESPONSAVEL_URL=https://exemplo.n8n.cloud/webhook/responsavel
